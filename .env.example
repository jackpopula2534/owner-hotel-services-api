# ============================================
# DATABASE (MySQL)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=hotel_services_db

# ============================================
# PRISMA
# ============================================
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:root@localhost:3306/hotel_services_db

# ============================================
# JWT / AUTHENTICATION
# ============================================
# JWT secret key (minimum 64 characters for security)
JWT_SECRET=952b9e6b192d670b3ca46913f6bd825a614dcf5a5f1ccb1b40215359f726d250b2e92d5602086296b3e11d4d08274dcb12978379c9b3c7e8ecc196cf43f82448
# JWT token expiration time
JWT_EXPIRES_IN=24h

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=9011
APP_NAME=Hotel Services
FRONTEND_URL=http://localhost:9010

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:2000,http://localhost:9010,http://localhost:9011

# ============================================
# REDIS
# ============================================
# Redis configuration for Bull job queue and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# SMTP / EMAIL
# ============================================
# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
# Sender information for emails
SMTP_FROM_EMAIL=noreply@hotel.com
SMTP_FROM_NAME=Hotel Services

# ============================================
# FIREBASE (PUSH NOTIFICATIONS)
# ============================================
