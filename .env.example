# ============================================
# LINE NOTIFY
# ============================================
# LINE Notify OAuth credentials for user notifications
LINE_NOTIFY_CLIENT_ID=your-line-notify-client-id
LINE_NOTIFY_CLIENT_SECRET=your-line-notify-client-secret
# Callback URL for LINE Notify OAuth redirect
LINE_NOTIFY_CALLBACK_URL=http://localhost:9011/api/v1/line-notify/callback

# ============================================
# PROMPTPAY
# ============================================
# PromptPay payment configuration
PROMPTPAY_ID=0123456789  # Phone number (10 digits) or Tax ID (13 digits)
MERCHANT_NAME=Hotel Services
MERCHANT_CITY=Bangkok

# ============================================
# 2FA (SPEAKEASY)
# ============================================
# Two-factor authentication settings are configured via Speakeasy library
# No additional env vars required, but APP_NAME is used for TOTP label

# ============================================
# FILE UPLOAD
# ============================================
# Future: Add S3/Cloud storage configuration when file upload feature is implemented
# Example placeholders:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=hotel-services-bucket
# MAX_FILE_SIZE=5242880  # 5MB in bytes

# ============================================
# API URLS
# ============================================
# External API endpoints
NEXT_PUBLIC_API_URL=http://localhost:9011/api
