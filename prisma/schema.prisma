// ─── HousekeepingTask ─────────────────────────────────────────────────────────
model HousekeepingTask {
  id        String  @id @default(uuid())
  tenantId  String
  roomId    String
  bookingId String? // link to checkout booking

  type     String @default("daily") // daily | checkout | deep | turndown | inspection | urgent
  priority String @default("medium") // low | medium | high | urgent
  status   String @default("pending") // pending | in_progress | completed | inspected

  // Scheduling
  scheduledFor      DateTime? // เวลาที่ควรเริ่มทำ
  estimatedDuration Int       @default(30) // นาที

  // Execution Tracking
  actualStartTime DateTime?
  actualEndTime   DateTime?
  actualDuration  Int? // นาที (คำนวณจาก end - start)
  startTime       DateTime? // legacy alias
  endTime         DateTime? // legacy alias

  // Room Readiness
  roomReadyAt DateTime? // checkout + cleaningBufferMinutes

  // Assignment
  assignedToId         String?
  assignedToName       String? // denormalized
  completionPercentage Int?

  // QA
  inspectedById   String?
  inspectedByName String? // denormalized
  inspectedAt     DateTime?
  rating          Int? // 1-5
  inspectionNotes String?   @db.Text
  notes           String?   @db.Text

  createdAt DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @default(now()) @updatedAt @db.DateTime(6)

  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking     Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignedTo  Staff?   @relation("AssignedStaff", fields: [assignedToId], references: [id], onDelete: SetNull)
  inspectedBy Staff?   @relation("InspectorStaff", fields: [inspectedById], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([bookingId])
  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([assignedToId])
  @@index([scheduledFor])
  @@map("housekeeping_tasks")
}

// ─── Employee Code Configuration ────────────────────────────────────────────
// Each hotel (tenant) can define their own employee code pattern.
// Pattern elements: {PREFIX}, {DEPT}, {YYYY}, {YY}, {MM}, {NNNN}, {NNN}, {NN}
// Separator can be customised (-, /, .)
// Example: {PREFIX}-{DEPT}-{YYYY}-{NNNN} → MV-HR-2026-0001

model EmployeeCodeConfig {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  pattern        String   @default("{PREFIX}-{NNNN}") // e.g. {PREFIX}-{DEPT}-{YYYY}-{NNNN}
  prefix         String   @default("EMP")             // custom prefix text
  separator      String   @default("-")               // separator between elements
  digitLength    Int      @default(4)                  // number of digits for running number
  resetCycle     String   @default("NEVER")            // NEVER | YEARLY | MONTHLY
  nextNumber     Int      @default(1)                  // current running number counter
  lastResetDate  DateTime?                             // last time counter was reset
  includeYear    Boolean  @default(false)              // include year in pattern
  yearFormat     String   @default("YYYY")             // YYYY or YY
  includeDept    Boolean  @default(false)              // include department code
  deptSource     String   @default("CODE")             // CODE | NAME_SHORT (first 2-3 chars)
  isActive       Boolean  @default(true)
  sampleOutput   String?                               // cached preview e.g. "EMP-HR-2026-0001"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@map("employee_code_configs")
}

// ─── StaffCall ────────────────────────────────────────────────────────────────
// Calls from customers (via QR scan) or POS staff requesting attention at a table.
// Real-time via WebSocket + LINE Notify to on-duty staff.

enum StaffCallType {
  SERVICE     // General service request
  PAYMENT     // Request bill / payment
  WATER       // Refill water
  ASSISTANCE  // Need help
  CLEANUP     // Table cleanup
  CUSTOM      // Custom message
}

enum StaffCallStatus {
  PENDING       // Just created, waiting for staff
  ACKNOWLEDGED  // Staff has seen it / on the way
  RESOLVED      // Completed
  CANCELLED     // Cancelled by customer or staff
}

enum StaffCallSource {
  CUSTOMER  // Created via QR scan public page
  POS       // Created by POS staff on behalf of observation
}

model StaffCall {
  id           String          @id @default(uuid())
  tenantId     String
  restaurantId String
  tableId      String
  callType     StaffCallType   @default(SERVICE)
  status       StaffCallStatus @default(PENDING)
  source       StaffCallSource @default(CUSTOMER)
  message      String?         @db.Text
  customerName String?         // Name from QR scan (optional)

  // Assignment
  assignedToId String?         // Staff member who acknowledged
  assignedAt   DateTime?

  // Resolution
  resolvedAt   DateTime?
  resolvedById String?         // Staff member who resolved
  resolution   String?         @db.Text

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([createdAt])
  @@map("staff_calls")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██ INVENTORY MANAGEMENT MODULE (Add-on)
// ═══════════════════════════════════════════════════════════════════════════════
// Stock control, purchase orders, goods receive/issue, stock counts.
// Gated by INVENTORY_MODULE add-on subscription.

// ─── Warehouse / Storage Location ────────────────────────────────────────────
// Each property can have multiple warehouses (main store, kitchen store, etc.)

enum WarehouseType {
  GENERAL       // General purpose warehouse
  KITCHEN       // Kitchen / F&B storage
  HOUSEKEEPING  // Housekeeping supplies
  MAINTENANCE   // Maintenance parts & tools
  MINIBAR       // Minibar inventory
}

model Warehouse {
  id          String        @id @default(uuid())
  tenantId    String
  propertyId  String
  name        String
  code        String
  type        WarehouseType @default(GENERAL)
  location    String?       // Physical location description
  isDefault   Boolean       @default(false)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  warehouseStocks WarehouseStock[]
  stockMovements  StockMovement[]
  goodsReceives   GoodsReceive[]
  stockCounts     StockCount[]
  inventoryLots   InventoryLot[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId])
  @@index([propertyId])
  @@index([deletedAt])
  @@map("warehouses")
}

// ─── Item Category ───────────────────────────────────────────────────────────
// Hierarchical categories: F&B > Raw Materials > Vegetables

model ItemCategory {
  id          String  @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String? @db.Text
  parentId    String? // Self-referencing for tree structure
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ItemCategory[] @relation("CategoryTree")
  items    InventoryItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@map("item_categories")
}

// ─── Inventory Item (Master) ─────────────────────────────────────────────────
// Central item catalog — each item has SKU, unit, reorder config, cost method.

enum CostMethod {
  FIFO          // First In First Out
  WEIGHTED_AVG  // Weighted Average Cost
}

enum ItemUnit {
  PIECE
  BOX
  PACK
  KG
  G
  L
  ML
  BOTTLE
  CAN
  BAG
  ROLL
  SET
  PAIR
  SHEET
  METER
  DOZEN
}

model InventoryItem {
  id            String     @id @default(uuid())
  tenantId      String
  sku           String     // Stock Keeping Unit
  name          String
  description   String?    @db.Text
  categoryId    String?
  unit          ItemUnit   @default(PIECE)
  costMethod    CostMethod @default(WEIGHTED_AVG)
  reorderPoint  Int        @default(0)  // Minimum quantity before alert
  reorderQty    Int        @default(0)  // Suggested reorder quantity
  maxStock      Int?                    // Maximum stock level
  minStock      Int        @default(0)  // Minimum stock level
  barcode       String?
  brand         String?
  imageUrl      String?
  isPerishable  Boolean    @default(false)
  defaultShelfLifeDays Int?            // Default shelf life for perishable items
  requiresLotTracking  Boolean  @default(false)  // Force lot tracking (independent from isPerishable)
  requiresQC           Boolean  @default(false)  // Force QC record before accepting into stock
  defaultQCTemplateId  String?                   // Default QC template for this item
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  category         ItemCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  itemSuppliers    ItemSupplier[]
  warehouseStocks  WarehouseStock[]
  stockMovements   StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiveItems  GoodsReceiveItem[]
  stockCountItems    StockCountItem[]
  roomTypeTemplates          RoomTypeAmenityTemplate[]
  inventoryRecipeIngredients InventoryRecipeIngredient[]
  wasteRecords               WasteRecord[]
  purchaseRequisitionItems PurchaseRequisitionItem[]
  supplierQuoteItems       SupplierQuoteItem[]
  inventoryLots    InventoryLot[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([barcode])
  @@index([deletedAt])
  @@map("inventory_items")
}

// ─── Supplier ────────────────────────────────────────────────────────────────

model Supplier {
  id            String  @id @default(uuid())
  tenantId      String
  name          String
  code          String
  contactPerson String?
  email         String?
  phone         String?
  address       String? @db.Text
  taxId         String? // Tax identification number
  paymentTerms  String? // e.g. "NET30", "COD"
  leadTimeDays  Int?    // Average delivery lead time
  rating        Decimal? @db.Decimal(3, 2) // 0.00 - 5.00
  notes         String?  @db.Text
  tags          String?  // JSON array of tag IDs e.g. '["cleaning","preferred"]'
  emoji         String?  @default("🏢") // Display icon for UI
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  itemSuppliers  ItemSupplier[]
  purchaseOrders PurchaseOrder[]
  supplierQuotes SupplierQuote[]
  rfqRecipients  RfqSupplierRecipient[]
  quoteTokens    SupplierQuoteToken[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("suppliers")
}

// ─── Item ↔ Supplier (Many-to-Many with pricing) ────────────────────────────

model ItemSupplier {
  id         String  @id @default(uuid())
  itemId     String
  supplierId String
  unitPrice  Decimal @db.Decimal(10, 2)
  currency   String  @default("THB")
  minOrderQty Int?    // Minimum order quantity
  leadDays   Int?     // Specific lead time for this supplier-item
  isPreferred Boolean @default(false)
  lastOrderDate DateTime?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([itemId, supplierId])
  @@index([itemId])
  @@index([supplierId])
  @@map("item_suppliers")
}

// ─── Warehouse Stock (Current Balances) ──────────────────────────────────────

model WarehouseStock {
  id          String  @id @default(uuid())
  warehouseId String
  itemId      String
  quantity    Int     @default(0)
  avgCost     Decimal @default(0) @db.Decimal(10, 2) // Weighted average cost
  totalValue  Decimal @default(0) @db.Decimal(12, 2) // quantity * avgCost
  lastCountedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, itemId])
  @@index([warehouseId])
  @@index([itemId])
  @@map("warehouse_stocks")
}

// ─── Stock Movement ──────────────────────────────────────────────────────────
// Every stock change is recorded as a movement for full audit trail.

enum StockMovementType {
  GOODS_RECEIVE     // Receive from supplier (GR)
  GOODS_ISSUE       // Issue to department (GI)
  TRANSFER_IN       // Transfer received from another warehouse
  TRANSFER_OUT      // Transfer sent to another warehouse
  ADJUSTMENT_IN     // Positive stock adjustment
  ADJUSTMENT_OUT    // Negative stock adjustment
  RETURN_SUPPLIER   // Return to supplier
  WASTE             // Damaged / expired / wasted
}

model StockMovement {
  id            String            @id @default(uuid())
  tenantId      String
  warehouseId   String
  itemId        String
  type          StockMovementType
  quantity      Int               // Always positive; direction from type
  unitCost      Decimal           @db.Decimal(10, 2)
  totalCost     Decimal           @db.Decimal(12, 2)
  // Polymorphic reference to source document
  referenceType String?           // 'purchase_order' | 'housekeeping_task' | 'maintenance_task' | 'restaurant_order' | 'stock_count' | 'transfer'
  referenceId   String?
  // Transfer: link to destination/source warehouse
  transferWarehouseId String?
  notes         String?           @db.Text
  batchNumber   String?           // Lot/batch tracking (legacy)
  expiryDate    DateTime?         // For perishable items (legacy)
  lotId         String?           // Link to InventoryLot (lot tracking)
  createdBy     String            // User ID who created
  createdAt     DateTime          @default(now())

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  item      InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  lot       InventoryLot?  @relation("LotStockMovements", fields: [lotId], references: [id])

  @@index([tenantId])
  @@index([warehouseId])
  @@index([itemId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([lotId])
  @@map("stock_movements")
}

// ─── Purchase Order ──────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum PurchaseOrderDiscountMode {
  BEFORE_VAT
  AFTER_VAT
}

enum PurchaseOrderDiscountType {
  PERCENT
  AMOUNT
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  tenantId      String
  propertyId    String
  poNumber      String              // Auto-generated: PO-YYYYMM-NNNN
  supplierId    String
  warehouseId   String              // Target warehouse for delivery
  status        PurchaseOrderStatus @default(DRAFT)
  orderDate     DateTime            @default(now())
  expectedDate  DateTime?           // Expected delivery date
  subtotal      Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal             @default(0) @db.Decimal(10, 2)
  discountAmount Decimal            @default(0) @db.Decimal(10, 2) // legacy total discount
  // ─── New discount / VAT fields (2026-04) ─────────────────────
  discountMode          PurchaseOrderDiscountMode  @default(BEFORE_VAT)
  headerDiscount        Decimal                    @default(0) @db.Decimal(12, 2)
  headerDiscountType    PurchaseOrderDiscountType  @default(AMOUNT)
  calculationBreakdown  Json?                      // Step-by-step calc audit
  // ──────────────────────────────────────────────────────────────
  totalAmount   Decimal             @default(0) @db.Decimal(12, 2)
  currency      String              @default("THB")
  notes         String?             @db.Text
  internalNotes String?             @db.Text
  requestedBy   String              // User ID
  approvedBy    String?             // User ID
  approvedAt    DateTime?
  cancelledBy   String?
  cancelledAt   DateTime?
  cancelReason  String?             @db.Text
  quotationNumber   String?             // เลขที่ใบเสนอราคาจากซัพพลายเออร์
  quotationDate     DateTime?           // วันที่ใบเสนอราคา
  purchaseRequisitionId String?         // Link to PR that generated this PO
  // Payment / delivery terms (PO-specific; auto-filled from Supplier or SupplierQuote,
  // but admin may override per-PO). Added 2026-04 to fix PDF showing "-" for these.
  paymentTerms    String?             // e.g. "COD", "NET 30"
  deliveryAddress String?  @db.Text    // Ship-to address for this PO
  // ─── Sprint 4: Force close + variance tracking ──────────────────────────
  forceClosedAt     DateTime?           // Set when admin force-closes a PO with outstanding qty
  forceClosedBy     String?             // User ID who force-closed
  forceClosedReason String?  @db.Text   // Required reason for closing with variance
  // ────────────────────────────────────────────────────────────────────────
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  purchaseRequisition PurchaseRequisition? @relation(fields: [purchaseRequisitionId], references: [id])
  items         PurchaseOrderItem[]
  goodsReceives GoodsReceive[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([propertyId])
  @@index([supplierId])
  @@index([purchaseRequisitionId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  itemId          String
  quantity        Int
  receivedQty     Int     @default(0) // Track how much has been received
  unitPrice       Decimal @db.Decimal(10, 2)
  discount        Decimal @default(0) @db.Decimal(10, 2)
  discountType    PurchaseOrderDiscountType @default(PERCENT)
  taxRate         Decimal @default(0) @db.Decimal(5, 2) // e.g. 7.00 for 7%
  totalPrice      Decimal @db.Decimal(12, 2)
  notes           String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id])

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_items")
}

// ─── Goods Receive ───────────────────────────────────────────────────────────
// Records actual receipt of goods against a PO.

enum GoodsReceiveStatus {
  DRAFT
  INSPECTING     // Quality check in progress
  ACCEPTED
  PARTIAL_REJECT // Some items rejected
  REJECTED       // All items rejected
}

model GoodsReceive {
  id              String             @id @default(uuid())
  tenantId        String
  grNumber        String             // Auto-generated: GR-YYYYMM-NNNN
  purchaseOrderId String?            // Can receive without PO (walk-in purchase)
  warehouseId     String
  status          GoodsReceiveStatus @default(DRAFT)
  receiveDate     DateTime           @default(now())
  invoiceNumber   String?            // Supplier invoice reference
  invoiceDate     DateTime?
  subtotal        Decimal            @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal            @default(0) @db.Decimal(12, 2)
  notes           String?            @db.Text
  receivedBy      String             // User ID
  inspectedBy     String?
  inspectedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  items         GoodsReceiveItem[]
  qcRecords     QCRecord[]

  @@unique([tenantId, grNumber])
  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([warehouseId])
  @@index([receiveDate])
  @@map("goods_receives")
}

model GoodsReceiveItem {
  id             String  @id @default(uuid())
  goodsReceiveId String
  itemId         String
  orderedQty     Int?    // From PO (if linked)
  receivedQty    Int
  rejectedQty    Int     @default(0)
  unitCost       Decimal @db.Decimal(10, 2)
  totalCost      Decimal @db.Decimal(12, 2)
  batchNumber    String?
  expiryDate     DateTime?
  rejectReason   String? @db.Text
  notes          String? @db.Text
  createdAt      DateTime @default(now())

  lotId          String?
  qcRecordId     String?

  goodsReceive GoodsReceive  @relation(fields: [goodsReceiveId], references: [id], onDelete: Cascade)
  item         InventoryItem @relation(fields: [itemId], references: [id])

  @@index([goodsReceiveId])
  @@index([itemId])
  @@index([lotId])
  @@map("goods_receive_items")
}

// ─── Stock Count (Physical Inventory) ────────────────────────────────────────

enum StockCountStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  APPROVED   // Adjustments approved and posted
  CANCELLED
}

model StockCount {
  id          String           @id @default(uuid())
  tenantId    String
  warehouseId String
  countNumber String           // Auto-generated: SC-YYYYMM-NNNN
  countDate   DateTime
  status      StockCountStatus @default(PLANNED)
  countType   String           @default("full") // full | partial | cycle
  notes       String?          @db.Text
  totalVariance    Decimal     @default(0) @db.Decimal(12, 2) // Total variance value
  totalItems       Int         @default(0)
  countedItems     Int         @default(0)
  varianceItems    Int         @default(0)  // Items with variance
  createdBy   String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  items     StockCountItem[]

  @@unique([tenantId, countNumber])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
  @@index([countDate])
  @@map("stock_counts")
}

model StockCountItem {
  id           String  @id @default(uuid())
  stockCountId String
  itemId       String
  systemQty    Int     // Quantity in system at count time
  actualQty    Int?    // Actual counted quantity
  variance     Int?    // actualQty - systemQty
  varianceValue Decimal? @db.Decimal(12, 2) // variance * avgCost
  unitCost     Decimal  @db.Decimal(10, 2)  // avgCost at count time
  notes        String?  @db.Text
  countedBy    String?  // User ID
  countedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockCount StockCount    @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  item       InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([stockCountId, itemId])
  @@index([stockCountId])
  @@index([itemId])
  @@map("stock_count_items")
}

// ─── PO Number Sequence ──────────────────────────────────────────────────────
// Auto-increment counter per tenant per document type per period.

model DocumentSequence {
  id          String @id @default(uuid())
  tenantId    String
  docType     String // 'PO' | 'GR' | 'GI' | 'SC' | 'TF'
  prefix      String // e.g. 'PO', 'GR'
  yearMonth   String // 'YYYYMM'
  lastNumber  Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, docType, yearMonth])
  @@index([tenantId])
  @@map("document_sequences")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██ INVENTORY INTEGRATION — Room Type Templates & Recipe BOM
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Room Type Amenity Template ──────────────────────────────────────────────
// Defines which inventory items are consumed per housekeeping task by room type.
// e.g. Deluxe room checkout → 2x soap, 1x shampoo, 2x towels

model RoomTypeAmenityTemplate {
  id              String  @id @default(uuid())
  tenantId        String
  roomType        String  // matches Room.type (e.g. "standard", "deluxe", "suite")
  taskType        String  @default("checkout") // checkout | daily | deep | turndown
  itemId          String
  quantity        Int     @default(1)
  warehouseId     String? // optional: specific warehouse to deduct from
  isActive        Boolean @default(true)
  notes           String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roomType, taskType, itemId])
  @@index([tenantId])
  @@index([roomType])
  @@index([taskType])
  @@map("room_type_amenity_templates")
}

// ─── Inventory Recipe / Bill of Materials ─────────────────────────────────────
// Links inventory items to menu items for auto-deduction.
// Separate from MenuItemRecipe (restaurant module) which is for display purposes.
// This model connects to InventoryItem for stock deduction on order completion.

model InventoryRecipe {
  id          String  @id @default(uuid())
  tenantId    String
  menuItemId  String  // references restaurant menu item (loose coupling via string ID)
  menuItemName String // denormalized for display
  servings    Int     @default(1) // how many servings this recipe makes
  isActive    Boolean @default(true)
  notes       String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients InventoryRecipeIngredient[]

  @@unique([tenantId, menuItemId])
  @@index([tenantId])
  @@map("inventory_recipes")
}

model InventoryRecipeIngredient {
  id        String  @id @default(uuid())
  recipeId  String
  itemId    String
  quantity  Decimal @db.Decimal(10, 3) // e.g. 0.200 for 200g
  unit      String  // display unit (may differ from inventory item unit)
  wastagePercent Decimal @default(0) @db.Decimal(5, 2) // e.g. 10% wastage
  notes     String? @db.Text
  createdAt DateTime @default(now())

  recipe InventoryRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   InventoryItem   @relation(fields: [itemId], references: [id])

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
  @@map("inventory_recipe_ingredients")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██ COST ACCOUNTING MODULE (Add-on)
// ═══════════════════════════════════════════════════════════════════════════════
// Department-level cost tracking following USALI (Uniform System of Accounts
// for the Lodging Industry). Gated by COST_ACCOUNTING_MODULE add-on.
// Requires INVENTORY_MODULE as prerequisite for material cost data.

// ─── Cost Center (USALI Departments) ─────────────────────────────────────────

enum CostCenterType {
  ROOMS            // Rooms Division (Front Office, Reservations, Housekeeping)
  FOOD_BEVERAGE    // Food & Beverage (Kitchen, Restaurant, Bar, Banquet)
  ADMIN_GENERAL    // Administrative & General
  SALES_MARKETING  // Sales & Marketing
  MAINTENANCE_DEPT // Property Operations & Maintenance
  ENERGY           // Utilities / Energy
  OTHER_OPERATED   // Other Operated Departments
  UNDISTRIBUTED    // Undistributed Operating Expenses
}

model CostCenter {
  id              String         @id @default(uuid())
  tenantId        String
  propertyId      String
  name            String
  code            String         // e.g. "CC-ROOMS", "CC-FB"
  type            CostCenterType
  description     String?        @db.Text
  parentId        String?        // for sub-departments
  managerId       String?        // responsible user/employee
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  parent          CostCenter?    @relation("CostCenterTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        CostCenter[]   @relation("CostCenterTree")
  costEntries     CostEntry[]
  departmentPnLs  DepartmentPnL[]
  budgets         CostBudget[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId])
  @@index([propertyId])
  @@index([type])
  @@map("cost_centers")
}

// ─── Cost Type ───────────────────────────────────────────────────────────────

enum CostCategory {
  MATERIAL    // Direct material costs (from inventory)
  LABOR       // Salary, wages, benefits (from HR)
  OVERHEAD    // Utilities, depreciation, rent, insurance
  REVENUE     // Income entries (room revenue, F&B revenue)
  OTHER       // Miscellaneous
}

model CostType {
  id          String       @id @default(uuid())
  tenantId    String
  name        String       // e.g. "Room Amenities", "Staff Salary", "Electricity"
  code        String
  category    CostCategory
  description String?      @db.Text
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  costEntries CostEntry[]
  budgets     CostBudget[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@map("cost_types")
}

// ─── Cost Entry (Individual cost postings) ───────────────────────────────────
// Every cost or revenue is posted as an entry to a cost center + cost type.
// Entries can be auto-generated (from inventory movements, HR payroll) or manual.

model CostEntry {
  id            String       @id @default(uuid())
  tenantId      String
  propertyId    String
  costCenterId  String
  costTypeId    String
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("THB")
  period        String       // "YYYY-MM" e.g. "2026-04"
  entryDate     DateTime     @default(now())
  description   String?      @db.Text
  // Source tracking (auto vs manual)
  sourceType    String?      // 'stock_movement' | 'payroll' | 'invoice' | 'manual' | 'booking'
  sourceId      String?      // ID of the source record
  isAutoPosted  Boolean      @default(false)
  // Approval
  status        String       @default("posted") // posted | pending | reversed
  reversedById  String?      // if reversed, the reversing entry ID
  reversedAt    DateTime?
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  costCenter    CostCenter   @relation(fields: [costCenterId], references: [id])
  costType      CostType     @relation(fields: [costTypeId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([costCenterId])
  @@index([costTypeId])
  @@index([period])
  @@index([sourceType, sourceId])
  @@index([entryDate])
  @@map("cost_entries")
}

// ─── Period Close ────────────────────────────────────────────────────────────
// Monthly closing process: aggregate all cost entries into summary reports.

enum PeriodCloseStatus {
  OPEN          // Period is open for entries
  CLOSING       // Closing in progress
  CLOSED        // Period closed, entries locked
  REOPENED      // Reopened for adjustments
}

model PeriodClose {
  id            String            @id @default(uuid())
  tenantId      String
  propertyId    String
  year          Int
  month         Int               // 1-12
  period        String            // "YYYY-MM"
  status        PeriodCloseStatus @default(OPEN)
  // Totals (calculated at close time)
  totalRevenue     Decimal        @default(0) @db.Decimal(14, 2)
  totalMaterialCost Decimal       @default(0) @db.Decimal(14, 2)
  totalLaborCost   Decimal        @default(0) @db.Decimal(14, 2)
  totalOverhead    Decimal        @default(0) @db.Decimal(14, 2)
  totalOtherCost   Decimal        @default(0) @db.Decimal(14, 2)
  grossProfit      Decimal        @default(0) @db.Decimal(14, 2)
  netOperatingIncome Decimal      @default(0) @db.Decimal(14, 2)
  // Occupancy data (snapshot)
  totalRoomNights    Int          @default(0)
  occupiedRoomNights Int          @default(0)
  occupancyRate      Decimal      @default(0) @db.Decimal(5, 2) // percentage
  revPAR             Decimal      @default(0) @db.Decimal(10, 2) // Revenue Per Available Room
  costPerOccupiedRoom Decimal     @default(0) @db.Decimal(10, 2)
  // Process
  closedBy      String?
  closedAt      DateTime?
  reopenedBy    String?
  reopenedAt    DateTime?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  departmentPnLs DepartmentPnL[]
  roomCostAnalyses RoomCostAnalysis[]
  foodCostAnalyses FoodCostAnalysis[]

  @@unique([tenantId, propertyId, year, month])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@map("period_closes")
}

// ─── Department P&L (per Cost Center per Period) ─────────────────────────────

model DepartmentPnL {
  id              String    @id @default(uuid())
  periodCloseId   String
  costCenterId    String
  revenue         Decimal   @default(0) @db.Decimal(14, 2)
  materialCost    Decimal   @default(0) @db.Decimal(14, 2)
  laborCost       Decimal   @default(0) @db.Decimal(14, 2)
  overheadCost    Decimal   @default(0) @db.Decimal(14, 2)
  otherCost       Decimal   @default(0) @db.Decimal(14, 2)
  totalCost       Decimal   @default(0) @db.Decimal(14, 2)
  netProfit       Decimal   @default(0) @db.Decimal(14, 2)
  profitMargin    Decimal   @default(0) @db.Decimal(5, 2) // percentage
  createdAt       DateTime  @default(now())

  periodClose     PeriodClose @relation(fields: [periodCloseId], references: [id], onDelete: Cascade)
  costCenter      CostCenter  @relation(fields: [costCenterId], references: [id])

  @@unique([periodCloseId, costCenterId])
  @@index([periodCloseId])
  @@index([costCenterId])
  @@map("department_pnls")
}

// ─── Room Cost Analysis (per Room Type per Period) ───────────────────────────

model RoomCostAnalysis {
  id              String    @id @default(uuid())
  periodCloseId   String
  roomType        String
  totalNights     Int       @default(0)
  totalRevenue    Decimal   @default(0) @db.Decimal(14, 2)
  totalCost       Decimal   @default(0) @db.Decimal(14, 2)
  amenityCost     Decimal   @default(0) @db.Decimal(14, 2)
  laborCost       Decimal   @default(0) @db.Decimal(14, 2)
  revenuePerNight Decimal   @default(0) @db.Decimal(10, 2)
  costPerNight    Decimal   @default(0) @db.Decimal(10, 2)
  profitPerNight  Decimal   @default(0) @db.Decimal(10, 2)
  margin          Decimal   @default(0) @db.Decimal(5, 2) // percentage
  createdAt       DateTime  @default(now())

  periodClose     PeriodClose @relation(fields: [periodCloseId], references: [id], onDelete: Cascade)

  @@unique([periodCloseId, roomType])
  @@index([periodCloseId])
  @@map("room_cost_analyses")
}

// ─── Food Cost Analysis (per Menu Item per Period) ───────────────────────────

model FoodCostAnalysis {
  id              String    @id @default(uuid())
  periodCloseId   String
  menuItemId      String
  menuItemName    String    // denormalized
  quantitySold    Int       @default(0)
  totalRevenue    Decimal   @default(0) @db.Decimal(14, 2)
  ingredientCost  Decimal   @default(0) @db.Decimal(14, 2)
  sellingPrice    Decimal   @default(0) @db.Decimal(10, 2) // per unit
  costPerUnit     Decimal   @default(0) @db.Decimal(10, 2)
  foodCostPercent Decimal   @default(0) @db.Decimal(5, 2) // (ingredientCost/revenue)*100
  profitPerUnit   Decimal   @default(0) @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())

  periodClose     PeriodClose @relation(fields: [periodCloseId], references: [id], onDelete: Cascade)

  @@unique([periodCloseId, menuItemId])
  @@index([periodCloseId])
  @@map("food_cost_analyses")
}

// ─── Cost Budget (per Cost Center per Cost Type per Period) ──────────────────

model CostBudget {
  id            String   @id @default(uuid()) @db.VarChar(36)
  tenantId      String   @db.VarChar(36)
  propertyId    String   @db.VarChar(36)
  costCenterId  String   @db.VarChar(36)
  costTypeId    String   @db.VarChar(36)
  period        String   @db.VarChar(10) // "YYYY-MM"
  budgetAmount  Decimal  @db.Decimal(14, 2)
  actualAmount  Decimal  @default(0) @db.Decimal(14, 2) // updated during period close
  variance      Decimal  @default(0) @db.Decimal(14, 2) // budget - actual
  variancePercent Decimal @default(0) @db.Decimal(5, 2)
  notes         String?  @db.Text
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  costCenter    CostCenter @relation(fields: [costCenterId], references: [id])
  costType      CostType   @relation(fields: [costTypeId], references: [id])

  @@unique([tenantId, propertyId, costCenterId, costTypeId, period])
  @@index([tenantId])
  @@index([propertyId])
  @@index([period])
  @@map("cost_budgets")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██ PHASE 4 — ADVANCED COST ANALYTICS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Menu Engineering Matrix ─────────────────────────────────────────────────
// Classifies menu items into Stars, Plowhorses, Puzzles, Dogs based on
// popularity (quantity sold) vs profitability (contribution margin).

model MenuEngineeringSnapshot {
  id              String   @id @default(uuid())
  tenantId        String
  propertyId      String
  restaurantId    String?
  period          String   // "YYYY-MM"
  snapshotDate    DateTime @default(now())
  // Averages for quadrant calculation
  avgPopularity   Decimal  @default(0) @db.Decimal(10, 2) // avg qty sold across all items
  avgMargin       Decimal  @default(0) @db.Decimal(10, 2) // avg contribution margin %
  totalItems      Int      @default(0)
  starsCount      Int      @default(0) // high pop + high margin
  plowhorsesCount Int      @default(0) // high pop + low margin
  puzzlesCount    Int      @default(0) // low pop + high margin
  dogsCount       Int      @default(0) // low pop + low margin
  createdBy       String
  createdAt       DateTime @default(now())

  items           MenuEngineeringItem[]

  @@unique([tenantId, propertyId, period])
  @@index([tenantId])
  @@index([propertyId])
  @@map("menu_engineering_snapshots")
}

model MenuEngineeringItem {
  id              String  @id @default(uuid())
  snapshotId      String
  menuItemId      String
  menuItemName    String  // denormalized
  categoryName    String? // menu category
  quantitySold    Int     @default(0)
  sellingPrice    Decimal @db.Decimal(10, 2)
  ingredientCost  Decimal @db.Decimal(10, 2)
  contributionMargin Decimal @db.Decimal(10, 2)  // sellingPrice - ingredientCost
  marginPercent   Decimal @db.Decimal(5, 2)       // (margin/sellingPrice)*100
  totalRevenue    Decimal @db.Decimal(14, 2)
  totalCost       Decimal @db.Decimal(14, 2)
  totalProfit     Decimal @db.Decimal(14, 2)
  popularityIndex Decimal @db.Decimal(5, 2) // qty / avgQty * 100
  // Classification: STAR | PLOWHORSE | PUZZLE | DOG
  classification  String
  // Recommendations
  recommendation  String? @db.Text
  createdAt       DateTime @default(now())

  snapshot        MenuEngineeringSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([classification])
  @@map("menu_engineering_items")
}

// ─── Waste Tracking ──────────────────────────────────────────────────────────
// Tracks waste events separately from inventory adjustments for detailed analysis.

enum WasteReason {
  EXPIRED         // Past shelf life
  SPOILED         // Spoiled during storage
  OVERPRODUCTION  // Excess food prepared
  PLATE_WASTE     // Returned from guests
  PREPARATION     // Trimming/peeling waste
  DAMAGED         // Physical damage
  OTHER
}

model WasteRecord {
  id            String      @id @default(uuid())
  tenantId      String
  propertyId    String
  warehouseId   String
  itemId        String
  quantity      Decimal     @db.Decimal(10, 3)
  unit          String
  estimatedCost Decimal     @db.Decimal(10, 2)
  reason        WasteReason
  department    String?     // which department generated waste
  notes         String?     @db.Text
  wasteDate     DateTime    @default(now())
  // Link to stock movement (WASTE type)
  stockMovementId String?
  recordedBy    String      // userId
  createdAt     DateTime    @default(now())

  item          InventoryItem @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([itemId])
  @@index([reason])
  @@index([wasteDate])
  @@map("waste_records")
}

// ─── KPI Snapshot ────────────────────────────────────────────────────────────
// Daily/weekly/monthly KPI snapshots for dashboard widgets.

model CostKpiSnapshot {
  id              String   @id @default(uuid())
  tenantId        String
  propertyId      String
  snapshotDate    DateTime
  granularity     String   @default("daily") // daily | weekly | monthly
  // Revenue KPIs
  totalRevenue    Decimal  @default(0) @db.Decimal(14, 2)
  roomRevenue     Decimal  @default(0) @db.Decimal(14, 2)
  fbRevenue       Decimal  @default(0) @db.Decimal(14, 2)
  otherRevenue    Decimal  @default(0) @db.Decimal(14, 2)
  // Cost KPIs
  totalCost       Decimal  @default(0) @db.Decimal(14, 2)
  materialCost    Decimal  @default(0) @db.Decimal(14, 2)
  laborCost       Decimal  @default(0) @db.Decimal(14, 2)
  overheadCost    Decimal  @default(0) @db.Decimal(14, 2)
  // Profitability
  grossProfit     Decimal  @default(0) @db.Decimal(14, 2)
  gopAmount       Decimal  @default(0) @db.Decimal(14, 2) // Gross Operating Profit
  gopPercent      Decimal  @default(0) @db.Decimal(5, 2)
  // Occupancy
  occupancyRate   Decimal  @default(0) @db.Decimal(5, 2)
  adr             Decimal  @default(0) @db.Decimal(10, 2) // Average Daily Rate
  revPAR          Decimal  @default(0) @db.Decimal(10, 2) // Revenue Per Available Room
  costPOR         Decimal  @default(0) @db.Decimal(10, 2) // Cost Per Occupied Room
  // F&B
  foodCostPercent Decimal  @default(0) @db.Decimal(5, 2)
  beverageCostPercent Decimal @default(0) @db.Decimal(5, 2)
  // Inventory
  inventoryValue  Decimal  @default(0) @db.Decimal(14, 2)
  lowStockAlerts  Int      @default(0)
  outOfStockItems Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([tenantId, propertyId, snapshotDate, granularity])
  @@index([tenantId])
  @@index([propertyId])
  @@index([snapshotDate])
  @@index([granularity])
  @@map("cost_kpi_snapshots")
}

// ─── Purchase Requisition (PR) Workflow ──────────────────────────────────────

enum PurchaseRequisitionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PENDING_QUOTES     // ส่งขอใบเสนอราคาจากคู่ค้า
  QUOTES_RECEIVED    // ได้รับใบเสนอราคาแล้ว
  COMPARING          // กำลังเทียบราคา
  PO_CREATED         // สร้าง PO แล้ว
  CANCELLED
  CLOSED
}

model PurchaseRequisition {
  id            String                      @id @default(uuid())
  tenantId      String
  propertyId    String
  prNumber      String                      // Auto: PR-YYYYMM-NNNN
  status        PurchaseRequisitionStatus   @default(DRAFT)
  priority      String                      @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  requiredDate  DateTime?                   // วันที่ต้องการสินค้า
  purpose       String?                     @db.Text  // วัตถุประสงค์การสั่งซื้อ
  department    String?                     // แผนกที่ขอ
  notes         String?                     @db.Text
  internalNotes String?                     @db.Text
  requestedBy   String                      // User ID
  approvedBy    String?
  approvedAt    DateTime?
  cancelledBy   String?
  cancelledAt   DateTime?
  cancelReason  String?                     @db.Text
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  items           PurchaseRequisitionItem[]
  supplierQuotes  SupplierQuote[]
  priceComparisons PriceComparison[]
  purchaseOrders  PurchaseOrder[]
  rfqLinks        RfqPurchaseRequisition[]

  @@unique([tenantId, prNumber])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([requestedBy])
  @@map("purchase_requisitions")
}

model PurchaseRequisitionItem {
  id                      String  @id @default(uuid())
  purchaseRequisitionId   String
  itemId                  String
  quantity                Int
  estimatedUnitPrice      Decimal?  @db.Decimal(10, 2)  // ราคาประมาณการ
  estimatedTotalPrice     Decimal?  @db.Decimal(12, 2)
  specifications          String?   @db.Text  // คุณสมบัติ/สเปค
  preferredSupplierId     String?  // ซัพพลายเออร์ที่ต้องการ
  notes                   String?   @db.Text
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  purchaseRequisition PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)
  item                InventoryItem       @relation(fields: [itemId], references: [id])

  @@index([purchaseRequisitionId])
  @@index([itemId])
  @@map("purchase_requisition_items")
}

// ─── Supplier Quotes ─────────────────────────────────────────────────────────

enum SupplierQuoteStatus {
  REQUESTED        // ขอใบเสนอราคาแล้ว
  RECEIVED         // ได้รับใบเสนอราคา
  SELECTED         // ถูกเลือก
  REJECTED         // ไม่ถูกเลือก
  EXPIRED          // หมดอายุ
}

model SupplierQuote {
  id                      String              @id @default(uuid())
  tenantId                String
  purchaseRequisitionId   String
  requestForQuotationId   String?             // Link ไปยัง RFQ (optional สำหรับ legacy data)
  round                   Int                 @default(1)  // รอบการขอใบเสนอราคา (1 = รอบแรก)
  supplierId              String
  quoteNumber             String?             // เลขที่ใบเสนอราคาจากซัพพลายเออร์
  status                  SupplierQuoteStatus @default(REQUESTED)
  quotedDate              DateTime?           // วันที่เสนอราคา
  validUntil              DateTime?           // ใบเสนอราคาหมดอายุ
  deliveryDays            Int?                // จำนวนวันจัดส่ง
  paymentTerms            String?             // เงื่อนไขการชำระเงิน
  subtotal                Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount               Decimal             @default(0) @db.Decimal(10, 2)
  discountAmount          Decimal             @default(0) @db.Decimal(10, 2)
  totalAmount             Decimal             @default(0) @db.Decimal(12, 2)
  currency                String              @default("THB")
  notes                   String?             @db.Text
  attachmentUrl           String?             // URL ไฟล์แนบใบเสนอราคา
  requestedAt             DateTime            @default(now())
  receivedAt              DateTime?
  selectedAt              DateTime?
  rejectedAt              DateTime?
  rejectionReason         String?             @db.Text
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  purchaseRequisition PurchaseRequisition  @relation(fields: [purchaseRequisitionId], references: [id])
  requestForQuotation RequestForQuotation? @relation(fields: [requestForQuotationId], references: [id])
  supplier            Supplier             @relation(fields: [supplierId], references: [id])
  items               SupplierQuoteItem[]
  priceComparisons    PriceComparison[]
  accessTokens        SupplierQuoteToken[]

  @@unique([tenantId, purchaseRequisitionId, supplierId, round], map: "supplier_quotes_tenant_pr_supplier_round_key")
  @@index([tenantId])
  @@index([purchaseRequisitionId])
  @@index([requestForQuotationId])
  @@index([supplierId])
  @@index([status])
  @@map("supplier_quotes")
}

model SupplierQuoteItem {
  id              String  @id @default(uuid())
  supplierQuoteId String
  itemId          String
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  discount        Decimal @default(0) @db.Decimal(10, 2)
  taxRate         Decimal @default(0) @db.Decimal(5, 2)
  totalPrice      Decimal @db.Decimal(12, 2)
  leadTimeDays    Int?                // วันจัดส่งเฉพาะรายการ
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())

  supplierQuote SupplierQuote @relation(fields: [supplierQuoteId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id])

  @@index([supplierQuoteId])
  @@index([itemId])
  @@map("supplier_quote_items")
}

// ─── Request For Quotation (RFQ) ─────────────────────────────────────────────

enum RfqStatus {
  DRAFT              // ร่าง ยังไม่ส่ง
  SENT               // ส่งให้ซัพพลายเออร์แล้ว
  PARTIAL_RESPONSE   // ตอบกลับมาบางราย
  FULLY_RESPONDED    // ตอบกลับมาครบทุกราย
  EXPIRED            // หมดเขตตอบกลับ
  CANCELLED          // ยกเลิก
}

model RequestForQuotation {
  id            String     @id @default(uuid())
  tenantId      String
  propertyId    String
  rfqNumber     String     // Auto: RFQ-YYMM-XXXX
  status        RfqStatus  @default(DRAFT)
  round         Int        @default(1)  // รอบที่ 1, 2, 3 ... (สำหรับ re-solicit)
  parentRfqId   String?    // ถ้าเป็น re-solicit จะ link ไป RFQ รอบก่อน
  subject       String?    // หัวข้อ RFQ (เช่น "ขอใบเสนอราคาเครื่องครัว")
  coverLetter   String?    @db.Text  // ข้อความเปิด/หมายเหตุถึงซัพพลายเออร์
  customTerms   String?    @db.Text  // เงื่อนไขเฉพาะของ RFQ นี้
  templateId    String?    // อ้างอิง template (ถ้ามี)
  issuedAt      DateTime?  // วันที่ส่งจริง
  deadline      DateTime?  // วันสุดท้ายที่รับใบเสนอราคา
  createdBy     String     // User ID
  cancelledBy   String?
  cancelledAt   DateTime?
  cancelReason  String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  parentRfq      RequestForQuotation?     @relation("RfqResolicit", fields: [parentRfqId], references: [id])
  childRfqs      RequestForQuotation[]    @relation("RfqResolicit")
  prLinks        RfqPurchaseRequisition[]
  recipients     RfqSupplierRecipient[]
  supplierQuotes SupplierQuote[]
  accessTokens   SupplierQuoteToken[]

  @@unique([tenantId, rfqNumber])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([createdBy])
  @@index([parentRfqId])
  @@map("request_for_quotations")
}

// Join table: RFQ ↔ PR (รองรับ batching หลาย PR ใน RFQ เดียว)
model RfqPurchaseRequisition {
  id                      String   @id @default(uuid())
  requestForQuotationId   String
  purchaseRequisitionId   String
  createdAt               DateTime @default(now())

  requestForQuotation RequestForQuotation @relation(fields: [requestForQuotationId], references: [id], onDelete: Cascade)
  purchaseRequisition PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)

  @@unique([requestForQuotationId, purchaseRequisitionId], map: "rfq_pr_rfqId_prId_key")
  @@index([requestForQuotationId])
  @@index([purchaseRequisitionId])
  @@map("rfq_purchase_requisitions")
}

// Recipients: ซัพพลายเออร์ที่ถูกส่ง RFQ ไปหา + สถานะตอบกลับ
model RfqSupplierRecipient {
  id                      String    @id @default(uuid())
  requestForQuotationId   String
  supplierId              String
  sentAt                  DateTime?           // เวลาที่ส่งจริง (null ถ้ายังไม่ได้ส่ง)
  remindedAt              DateTime?           // เวลาเตือนล่าสุด
  remindCount             Int       @default(0)
  respondedAt             DateTime?           // ซัพพลายเออร์ตอบกลับเมื่อไร
  declinedAt              DateTime?           // ซัพพลายเออร์ปฏิเสธ
  declineReason           String?   @db.Text
  notes                   String?   @db.Text
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  requestForQuotation RequestForQuotation @relation(fields: [requestForQuotationId], references: [id], onDelete: Cascade)
  supplier            Supplier            @relation(fields: [supplierId], references: [id])

  @@unique([requestForQuotationId, supplierId])
  @@index([requestForQuotationId])
  @@index([supplierId])
  @@map("rfq_supplier_recipients")
}

// ─── Supplier Quote Access Token (magic link) ───────────────────────────────
// Single-use-ish token ที่ส่งใน email ให้ supplier กรอก quote ผ่าน public portal
// หมดอายุผูกกับ RFQ.deadline (+ buffer optional). admin revoke ได้
model SupplierQuoteToken {
  id                      String    @id @default(uuid())
  tenantId                String
  supplierQuoteId         String
  requestForQuotationId   String
  supplierId              String
  tokenHash               String    @unique              // sha256(rawToken)
  expiresAt               DateTime
  usedAt                  DateTime?                      // supplier submit แล้ว
  revokedAt               DateTime?                      // admin revoke / regen
  lastAccessedAt          DateTime?                      // GET session ครั้งล่าสุด
  accessCount             Int       @default(0)
  createdAt               DateTime  @default(now())

  supplierQuote       SupplierQuote       @relation(fields: [supplierQuoteId], references: [id], onDelete: Cascade)
  requestForQuotation RequestForQuotation @relation(fields: [requestForQuotationId], references: [id], onDelete: Cascade)
  supplier            Supplier            @relation(fields: [supplierId], references: [id])

  @@index([tenantId])
  @@index([supplierQuoteId])
  @@index([requestForQuotationId])
  @@index([supplierId])
  @@index([expiresAt])
  @@map("supplier_quote_tokens")
}

// ─── Price Comparison ───────────────────────────────────────────────────────

enum PriceComparisonStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model PriceComparison {
  id                      String  @id @default(uuid())
  tenantId                String
  purchaseRequisitionId   String
  comparisonNumber        String              // Auto: PC-YYYYMM-NNNN
  selectedQuoteId         String?             // ใบเสนอราคาที่เลือก
  selectionReason         String?             @db.Text  // เหตุผลที่เลือก
  comparedBy              String              // User ID
  comparedAt              DateTime            @default(now())
  status                  PriceComparisonStatus @default(DRAFT)
  submittedAt             DateTime?
  approvedBy              String?
  approvedAt              DateTime?
  rejectedBy              String?
  rejectedAt              DateTime?
  rejectionReason         String?             @db.Text
  notes                   String?             @db.Text
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  purchaseRequisition PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id])
  selectedQuote       SupplierQuote?       @relation(fields: [selectedQuoteId], references: [id])

  @@unique([tenantId, comparisonNumber])
  @@unique([tenantId, purchaseRequisitionId])
  @@index([tenantId])
  @@index([purchaseRequisitionId])
  @@index([status])
  @@map("price_comparisons")
}

// ─── Document Settings (per property) ────────────────────────────────────────
model DocumentSettings {
  id              String   @id @default(uuid())
  tenantId        String
  propertyId      String

  // Company / Header Info
  companyName     String?           // ชื่อบริษัท (override property name)
  companyNameEn   String?           // ชื่อบริษัท (English)
  taxId           String?           // เลขประจำตัวผู้เสียภาษี
  branchName      String?           // สำนักงานใหญ่ / สาขา
  branchNumber    String?           // เลขที่สาขา
  address         String?  @db.Text // ที่อยู่บริษัท
  addressEn       String?  @db.Text // ที่อยู่บริษัท (English)
  // Shipping / Delivery address — used as default ship-to in PO when admin
  // selects "ที่อยู่จัดส่ง" instead of the billing/company address.
  shippingAddress   String? @db.Text // ที่อยู่จัดส่ง (ภาษาไทย)
  shippingAddressEn String? @db.Text // ที่อยู่จัดส่ง (English)
  phone           String?           // เบอร์โทร
  fax             String?           // เบอร์แฟกซ์
  email           String?           // อีเมล
  website         String?           // เว็บไซต์

  // Logo
  logoUrl         String?           // URL ของ Logo
  logoWidth       Int?     @default(40) // ความกว้าง Logo (mm) ใน PDF
  logoHeight      Int?     @default(40) // ความสูง Logo (mm) ใน PDF
  logoOffsetX     Float?   @default(0)  // ตำแหน่งเยื้องแนวนอน (mm) — รองรับ 0.5 step
  logoOffsetY     Float?   @default(0)  // ตำแหน่งเยื้องแนวตั้ง (mm) — รองรับ 0.5 step
  logoPosition    String   @default("left")   // left | center | right
  logoFrameStyle  String   @default("plain")  // plain | framed
  logoVerticalAlign String @default("center") // top | center | bottom

  // Payment / Bank Info
  bankName        String?           // ชื่อธนาคาร
  bankBranch      String?           // สาขาธนาคาร
  bankAccountName String?           // ชื่อบัญชี
  bankAccountNumber String?         // เลขที่บัญชี

  // Document Appearance
  primaryColor    String   @default("#7C3AED") // สี Header หลัก
  showLogo        Boolean  @default(true)
  showCompanyName Boolean  @default(true)
  showTaxId       Boolean  @default(true)
  showAddress     Boolean  @default(true)
  showPhone       Boolean  @default(true)
  showBankInfo    Boolean  @default(false)
  showSignatureLine Boolean @default(true) // ช่องลายเซ็น

  // PO-specific settings
  poTermsAndConditions String? @db.Text  // เงื่อนไขใน PO
  poFooterNote         String? @db.Text  // หมายเหตุท้าย PO

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, propertyId])
  @@index([tenantId])
  @@index([propertyId])
  @@map("document_settings")
}

// ─── Inventory Lot Tracking ───────────────────────────────────────────────────

enum InventoryLotStatus {
  ACTIVE        // ใช้งานได้
  QUARANTINED   // รอ QC / กักกัน
  EXHAUSTED     // remainingQty = 0
  EXPIRED       // เลย expiryDate
  DISPOSED      // ทำลายแล้ว (waste)
}

model InventoryLot {
  id              String             @id @default(uuid())
  tenantId        String
  itemId          String
  warehouseId     String
  lotNumber       String             // Auto: LOT-YYYYMM-NNNN
  batchNumber     String?            // เลข batch จาก supplier (ถ้ามี)
  grItemId        String?            // Link to GoodsReceiveItem
  supplierId      String?
  receivedDate    DateTime           @default(now())
  manufactureDate DateTime?
  expiryDate      DateTime?
  initialQty      Int
  remainingQty    Int
  unitCost        Decimal            @db.Decimal(10, 2)
  status          InventoryLotStatus @default(ACTIVE)
  qrPayload       String?            @db.Text  // pre-signed payload for fast lookup
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  item            InventoryItem      @relation(fields: [itemId], references: [id])
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  stockMovements  StockMovement[]    @relation("LotStockMovements")
  qcRecords       QCRecord[]

  @@unique([tenantId, lotNumber])
  @@index([tenantId, itemId, warehouseId, status])
  @@index([expiryDate])
  @@index([grItemId])
  @@map("inventory_lots")
}

// ─── Quality Control (QC) ─────────────────────────────────────────────────────

model QCTemplate {
  id           String            @id @default(uuid())
  tenantId     String
  name         String
  appliesTo    String            // 'CATEGORY' | 'ITEM'
  categoryId   String?
  itemId       String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  checklistItems QCChecklistItem[]
  records        QCRecord[]

  @@index([tenantId, appliesTo])
  @@map("qc_templates")
}

model QCChecklistItem {
  id            String      @id @default(uuid())
  templateId    String
  label         String      // เช่น "สี/กลิ่นปกติ", "อุณหภูมิ ≤ 4°C"
  type          String      // 'BOOLEAN' | 'NUMERIC' | 'TEXT' | 'PHOTO'
  required      Boolean     @default(true)
  passCondition Json?       // เช่น { op: "lte", value: 4 } สำหรับ NUMERIC
  orderIndex    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  template      QCTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results       QCResult[]

  @@index([templateId])
  @@map("qc_checklist_items")
}

enum QCRecordStatus {
  PENDING
  PASSED
  PARTIAL_FAIL
  FAILED
}

model QCRecord {
  id              String          @id @default(uuid())
  tenantId        String
  templateId      String
  goodsReceiveId  String?
  lotId           String?
  status          QCRecordStatus  @default(PENDING)
  inspectedBy     String
  inspectedAt     DateTime        @default(now())
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  template        QCTemplate      @relation(fields: [templateId], references: [id])
  lot             InventoryLot?   @relation(fields: [lotId], references: [id])
  goodsReceive    GoodsReceive?   @relation(fields: [goodsReceiveId], references: [id])
  results         QCResult[]

  @@index([tenantId])
  @@index([goodsReceiveId])
  @@index([lotId])
  @@map("qc_records")
}

model QCResult {
  id                String          @id @default(uuid())
  recordId          String
  checklistItemId   String
  valueBool         Boolean?
  valueNumeric      Decimal?        @db.Decimal(10, 2)
  valueText         String?         @db.Text
  photoUrls         Json?           // array of Firebase Storage URLs
  passed            Boolean
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  record            QCRecord        @relation(fields: [recordId], references: [id], onDelete: Cascade)
  checklistItem     QCChecklistItem @relation(fields: [checklistItemId], references: [id])

  @@index([recordId])
  @@map("qc_results")
}

// ══════════════════════════════════════════════════════════════════════════════
// PROCUREMENT APPROVAL FLOW
// ══════════════════════════════════════════════════════════════════════════════

enum ApprovalDocumentType {
  PURCHASE_REQUISITION
  PRICE_COMPARISON
  PURCHASE_ORDER
}

enum ApproverType {
  SPECIFIC_USER
  ROLE
  DEPARTMENT_HEAD
}

/// Approval Flow Template.
/// Tenant-wide rule describing how PR / Price Comparison / PO must be approved.
/// Multiple flows per document type are allowed; the engine picks the best match
/// by (documentType, amount within [minAmount, maxAmount], isActive, isDefault).
model ApprovalFlow {
  id            String               @id @default(uuid())
  tenantId      String
  propertyId    String?
  name          String               @db.VarChar(150)
  description   String?              @db.Text
  documentType  ApprovalDocumentType
  minAmount     Decimal?             @db.Decimal(12, 2)
  maxAmount     Decimal?             @db.Decimal(12, 2)
  isActive      Boolean              @default(true)
  isDefault     Boolean              @default(false)
  createdBy     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  steps         ApprovalFlowStep[]

  @@index([tenantId, documentType])
  @@index([tenantId, isActive])
  @@map("approval_flows")
}

/// A single step in an approval flow (executed sequentially by stepOrder).
/// If isParallel = true, ALL approvers assigned via ApprovalFlowStepApprover must
/// approve (or a minApprovals threshold, whichever is lower).
model ApprovalFlowStep {
  id            String        @id @default(uuid())
  flowId        String
  stepOrder     Int
  name          String        @db.VarChar(150)
  approverType  ApproverType  @default(SPECIFIC_USER)
  approverRole  String?
  minApprovals  Int           @default(1)
  isParallel    Boolean       @default(false)
  slaHours      Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  flow          ApprovalFlow               @relation(fields: [flowId], references: [id], onDelete: Cascade)
  approvers     ApprovalFlowStepApprover[]

  @@unique([flowId, stepOrder])
  @@index([flowId])
  @@map("approval_flow_steps")
}

/// Join table: which users are approvers for a given step.
/// Only used when the parent step's approverType = SPECIFIC_USER.
model ApprovalFlowStepApprover {
  id        String           @id @default(uuid())
  stepId    String
  userId    String
  order     Int              @default(0)
  createdAt DateTime         @default(now())

  step      ApprovalFlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stepId, userId])
  @@index([userId])
  @@map("approval_flow_step_approvers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Bank Accounts — master data for company bank accounts shown on billing page.
// Supports multiple banks; customers pick one when paying via bank transfer.
// ─────────────────────────────────────────────────────────────────────────────
model BankAccount {
  id            String   @id @default(uuid())
  /// ชื่อธนาคาร เช่น "กสิกรไทย", "ไทยพาณิชย์"
  bankName      String   @db.VarChar(100)
  /// รหัสธนาคาร เช่น "KBANK", "SCB", "KTB"
  bankCode      String   @db.VarChar(20)
  /// ชื่อบัญชี
  accountName   String   @db.VarChar(200)
  /// เลขที่บัญชี
  accountNumber String   @db.VarChar(20)
  /// สาขา (optional)
  branch        String?  @db.VarChar(150)
  /// URL โลโก้ธนาคาร (optional)
  logoUrl       String?  @db.VarChar(500)
  /// แสดงบนหน้า billing หรือไม่
  isActive      Boolean  @default(true)
  /// บัญชีหลัก — แสดงขึ้นก่อน
  isDefault     Boolean  @default(false)
  /// ลำดับการแสดงผล
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("bank_accounts")
}

