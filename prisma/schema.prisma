// ==================== Housekeeping Management ====================
// ─── Staff ────────────────────────────────────────────────────────────────────
model Staff {
  id               String   @id @default(uuid())
  tenantId         String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String // housekeeper | technician | supervisor | manager
  department       String? // housekeeping | maintenance | front_desk
  employeeCode     String?
  status           String   @default("active") // active | inactive | on_leave
  shiftType        String? // morning | afternoon | night | flexible
  maxTasksPerShift Int?     @default(8)
  specializations  String?  @db.Text // JSON: ["deep-cleaning","ac-repair"]
  rating           Decimal? @db.Decimal(3, 2)
  efficiency       Int?     @default(100)

  // HR Add-on: optional link to Employee record (requires HR_MODULE add-on)
  employeeId String?   @unique
  employee   Employee? @relation("StaffEmployee", fields: [employeeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  housekeepingTasks    HousekeepingTask[] @relation("AssignedStaff")
  inspectedTasks       HousekeepingTask[] @relation("InspectorStaff")
  maintenanceTasks     MaintenanceTask[]  @relation("AssignedTechnician")
  inspectedMaintenance MaintenanceTask[]  @relation("InspectorTechnician")

  @@index([tenantId])
  @@index([status])
  @@index([department])
  @@index([employeeId])
  @@map("staff")
}

// ─── MaintenanceTask ──────────────────────────────────────────────────────────
model MaintenanceTask {
  id         String  @id @default(uuid())
  tenantId   String
  propertyId String
  roomId     String?

  title       String
  description String? @db.Text
  category    String // ac | plumbing | electrical | furniture | structural | pest | safety | other
  priority    String  @default("medium") // low | medium | high | urgent
  status      String  @default("pending") // pending | in_progress | completed | on_hold | cancelled

  // Scheduling
  assignedToId      String?
  requestedDate     DateTime?
  scheduledDate     DateTime?
  estimatedDuration Int? // นาที

  // Execution
  startedAt      DateTime?
  completedAt    DateTime?
  actualDuration Int? // นาที

  // Cost
  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)
  partsUsed     String?  @db.Text // JSON: [{name,qty,cost}]

  // QA
  inspectedById   String?
  inspectedAt     DateTime?
  rating          Int? // 1-5
  inspectionNotes String?   @db.Text

  notes       String? @db.Text
  attachments String? @db.Text // JSON: [urls]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room        Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  assignedTo  Staff?   @relation("AssignedTechnician", fields: [assignedToId], references: [id], onDelete: SetNull)
  inspectedBy Staff?   @relation("InspectorTechnician", fields: [inspectedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([status])
  @@index([category])
  @@index([assignedToId])
  @@map("maintenance_tasks")
}

// ─── BookingAddOn ─────────────────────────────────────────────────────────────
model BookingAddOn {
