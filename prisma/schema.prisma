generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String?
  lastName      String?
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  authProvider  String         @default("local")
  employeeId    String?
  language      String?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  metadata      String?        @db.Text
  phone         String?
  status        String         @default("active")
  tenantId       String? // activeTenantId for current session context
  timezone       String?
  // ── System Access Control ─────────────────────────────────────────────────
  // JSON-encoded array: ["main"] | ["pos"] | ["main","pos"]
  // Controls which system(s) this user may log into.
  // main = hotel management dashboard, pos = Point-of-Sale terminal
  allowedSystems String         @default("[\"main\"]") @db.VarChar(255)
  // ─────────────────────────────────────────────────────────────────────────
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  userTenants    UserTenant[] // Junction table for multi-tenant support

  @@map("users")
}

model Admin {
  id            String         @id @default(uuid()) @db.VarChar(36)
  firstName     String?
  lastName      String?
  email         String         @unique(map: "IDX_051db7d37d478a69a7432df147")
  password      String
  role          String         @default("platform_admin")
  status        String         @default("active")
  lastLoginAt   DateTime?      @db.DateTime(0)
  lastLoginIp   String?
  createdAt     DateTime       @default(now()) @db.DateTime(6)
  updatedAt     DateTime       @default(now()) @updatedAt @db.DateTime(6)
  refreshTokens RefreshToken[]

  @@map("admins")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.VarChar(36)
  token       String    @unique
  userId      String?   @db.VarChar(36)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  adminId     String?   @db.VarChar(36)
  // ── Device Fingerprint (session management) ──────────────────────────────
  deviceName  String?   @db.VarChar(255)
  deviceType  String?   @db.VarChar(50)
  ipAddress   String?   @db.VarChar(45)
  userAgent   String?   @db.Text
  lastUsedAt    DateTime?
  lastUsedIp    String?   @db.VarChar(45)
  // ── System Context ────────────────────────────────────────────────────────
  // Identifies which system issued this token: 'main' | 'pos'
  // Logout from POS only revokes tokens where systemContext = 'pos'
  systemContext String    @default("main") @db.VarChar(20)
  // ─────────────────────────────────────────────────────────────────────────
  admin         Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([adminId])
  @@index([userId, lastUsedAt])
  @@index([userId, systemContext])
  @@map("refresh_tokens")
}

model password_resets {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([email])
  @@map("password_resets")
}

model Guest {
  id             String    @id @default(uuid())
  tenantId       String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  nationalId     String?
  passportNumber String?
  dateOfBirth    String?
  nationality    String?
  address        String?
  city           String?
  country        String?
  postalCode     String?
  isVip              Boolean   @default(false)
  vipLevel           String?
  vehiclePlateNumber String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  bookings           Booking[]

  @@index([tenantId])
  @@map("guests")
}

model Property {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  code        String
  location    String?
  description String?   @db.Text
  phone       String?
  email       String?
  isDefault   Boolean   @default(false)
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? @map("deleted_at")

  // Service Charge & VAT Settings
  serviceChargeEnabled Boolean @default(true)
  serviceChargePercent Float   @default(10)
  vatEnabled           Boolean @default(true)
  vatPercent           Float   @default(7)
  taxDisplayMode       String  @default("breakdown")

  // Check-in / Check-out Time Settings
  standardCheckInTime   String   @default("14:00") // HH:mm
  standardCheckOutTime  String   @default("12:00") // HH:mm
  cleaningBufferMinutes Int      @default(60) // นาทีหลัง checkout ก่อนห้องพร้อม
  earlyCheckInEnabled   Boolean  @default(false)
  lateCheckOutEnabled   Boolean  @default(false)
  earlyCheckInFeeType   String?  @default("fixed") // "fixed" | "percentage"
  earlyCheckInFeeAmount Decimal? @db.Decimal(10, 2)
  lateCheckOutFeeType   String?  @default("fixed") // "fixed" | "percentage"
  lateCheckOutFeeAmount Decimal? @db.Decimal(10, 2)
  timezone              String   @default("Asia/Bangkok")

  rooms            Room[]
  bookings         Booking[]
  maintenanceTasks MaintenanceTask[]
  employees        Employee[]
  restaurants      Restaurant[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("properties")
}

model Room {
  id              String  @id @default(uuid())
  tenantId        String?
  propertyId      String
  number          String
  type            String
  floor           Int?
  price           Decimal @db.Decimal(10, 2)
  status          String  @default("available")
  maxOccupancy    Int?    @default(2)
  bedType         String?
  size            Int?
  amenities       Json?
  extraBedAllowed Boolean @default(false)
  extraBedLimit   Int     @default(0)
  extraBedPrice   Decimal @default(0) @db.Decimal(10, 2)
  description     String?
  images          Json?

  // Dynamic Pricing
  weekendPrice           Decimal? @db.Decimal(10, 2)
  holidayPriceEnabled    Boolean  @default(false)
  holidayPriceType       String?
  holidayPrice           Decimal? @db.Decimal(10, 2)
  holidayPricePercent    Float?
  seasonalRates          Json?
  childNoExtraCharge     Boolean  @default(false)
  childNoExtraChargeNote String?  @db.Text

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  housekeepingTasks HousekeepingTask[]
  maintenanceTasks  MaintenanceTask[]

  @@unique([propertyId, number])
  @@index([tenantId])
  @@index([propertyId])
  @@map("rooms")
}

model Booking {
  id                String    @id @default(uuid())
  tenantId          String?
  propertyId        String
  guestId           String?
  roomId            String
  guestFirstName    String
  guestLastName     String
  guestEmail        String?
  guestPhone        String?
  adults            Int?      @default(1)
  children          Int?      @default(0)
  numberOfGuests    Int?      @default(1)
  baseCapacity      Int?      @default(2)
  extraBedCapacity  Int?      @default(0)
  totalCapacity     Int?      @default(2)
  extraBedGuests    Int?      @default(0)
  standardBedGuests Int?      @default(1)
  checkIn           DateTime
  checkOut          DateTime
  // Scheduled times (date + standard property time)
  scheduledCheckIn  DateTime?
  scheduledCheckOut DateTime?
  actualCheckIn     DateTime?
  actualCheckOut    DateTime?

  // Early Check-in / Late Check-out
  requestedEarlyCheckIn Boolean? @default(false)
  approvedEarlyCheckIn  Boolean? @default(false)
  earlyCheckInFee       Decimal? @db.Decimal(10, 2)
  requestedLateCheckOut Boolean? @default(false)
  approvedLateCheckOut  Boolean? @default(false)
  lateCheckOutFee       Decimal? @db.Decimal(10, 2)

  status              String   @default("pending")
  totalPrice          Decimal  @db.Decimal(10, 2)
  roomSubtotal        Decimal? @db.Decimal(10, 2)
  serviceChargeAmount Decimal? @db.Decimal(10, 2)
  vatAmount           Decimal? @db.Decimal(10, 2)
  grandTotal          Decimal? @db.Decimal(10, 2)
  pricingBreakdown    Json?
  source              String?
  notes               String?

  // Payment Fields
  paymentMethod String?
  paymentStatus String?  @default("pending")
  amountPaid    Decimal? @db.Decimal(10, 2)
  paymentNote   String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  channelId         String?
  channel           Channel?           @relation(fields: [channelId], references: [id])
  guest             Guest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)
  room              Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  review            Review?
  housekeepingTasks HousekeepingTask[]
  addOns            BookingAddOn[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([channelId], map: "bookings_channelId_fkey")
  @@index([guestId], map: "bookings_guestId_fkey")
  @@index([roomId], map: "bookings_roomId_fkey")
  @@index([scheduledCheckIn])
  @@index([scheduledCheckOut])
  @@index([status])
  @@map("bookings")
}

model Review {
  id        String   @id @default(uuid())
  tenantId  String?
  bookingId String?  @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("reviews")
}

// ─── Restaurant Enums ────────────────────────────────────────────────────────

enum RestaurantType {
  FINE_DINING
  CASUAL
  BUFFET
  BAR
  CAFE
  POOL_BAR
  ROOM_SERVICE
}

enum TableShape {
  RECTANGLE
  SQUARE
  ROUND
  OVAL
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  CLEANING
  OUT_OF_SERVICE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ROOM_SERVICE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenPriority {
  LOW
  NORMAL
  HIGH
  RUSH
}

// ─── Restaurant Core ─────────────────────────────────────────────────────────

model Restaurant {
  id          String         @id @default(uuid())
  tenantId    String?
  propertyId  String?
  name        String
  code        String         @unique
  type        RestaurantType @default(CASUAL)
  description String?
  location    String?
  capacity    Int?
  openTime    String?
  closeTime   String?
  isActive    Boolean        @default(true)
  layoutData  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  property     Property?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tables       RestaurantTable[]
  menuCategories MenuCategory[]
  orders       Order[]
  staffCalls   StaffCall[]

  @@index([tenantId])
  @@index([propertyId])
  @@map("restaurants")
}

model RestaurantTable {
  id           String      @id @default(uuid())
  tenantId     String?
  restaurantId String
  tableNumber  String
  capacity     Int
  shape        TableShape  @default(RECTANGLE)
  status       TableStatus @default(AVAILABLE)
  positionX    Float?
  positionY    Float?
  width        Float?
  height       Float?
  rotation     Float?      @default(0)
  zone         String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations TableReservation[]
  orders       Order[]
  staffCalls   StaffCall[]

  @@unique([restaurantId, tableNumber])
  @@index([tenantId])
  @@index([restaurantId])
  @@index([status])
  @@map("restaurant_tables")
}

model TableReservation {
  id              String            @id @default(uuid())
  tenantId        String?
  restaurantId    String
  tableId         String
  guestName       String
  guestPhone      String?
  guestEmail      String?
  partySize       Int
  reservationDate DateTime          @db.Date
  startTime       String
  endTime         String?
  status          ReservationStatus @default(PENDING)
  specialRequests String?
  notes           String?           @db.Text
  confirmedAt     DateTime?
  seatedAt        DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  table RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@index([tableId])
  @@index([reservationDate])
  @@index([status])
  @@map("table_reservations")
}

// ─── Menu ────────────────────────────────────────────────────────────────────

model MenuCategory {
  id           String   @id @default(uuid())
  tenantId     String?
  restaurantId String
  name         String
  description  String?
  image        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([tenantId])
  @@index([restaurantId])
  @@map("menu_categories")
}

model MenuItem {
  id              String   @id @default(uuid())
  tenantId        String?
  restaurantId    String
  categoryId      String
  name            String
  description     String?  @db.Text
  price           Decimal  @db.Decimal(10, 2)
  cost            Decimal? @db.Decimal(10, 2)
  image           String?  @db.LongText
  preparationTime Int?
  calories        Int?
  allergens       Json?
  isVegetarian    Boolean  @default(false)
  isVegan         Boolean  @default(false)
  isGlutenFree    Boolean  @default(false)
  isSpicy         Boolean  @default(false)
  spicyLevel      Int?
  isAvailable     Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   MenuCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  recipe     MenuItemRecipe?

  @@index([tenantId])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@map("menu_items")
}

// ─── Recipes ──────────────────────────────────────────────────────────────────

model MenuItemRecipe {
  id           String             @id @default(uuid())
  menuItemId   String             @unique
  servings     Int?
  instructions String?            @db.Text
  notes        String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  menuItem     MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients  RecipeIngredient[]

  @@map("menu_item_recipes")
}

model RecipeIngredient {
  id           String         @id @default(uuid())
  recipeId     String
  name         String
  quantity     Decimal?       @db.Decimal(10, 3)
  unit         String?
  notes        String?
  displayOrder Int            @default(0)

  recipe       MenuItemRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("recipe_ingredients")
}

// ─── Orders / POS ────────────────────────────────────────────────────────────

model Order {
  id            String             @id @default(uuid())
  tenantId      String?
  restaurantId  String
  tableId       String?
  orderNumber   String             @unique
  orderType     OrderType          @default(DINE_IN)
  status        OrderStatus        @default(PENDING)
  waiterId      String?
  guestName     String?
  guestRoom     String?
  partySize     Int?
  subtotal      Decimal            @default(0) @db.Decimal(10, 2)
  taxRate       Decimal            @default(7) @db.Decimal(5, 2)
  taxAmount     Decimal            @default(0) @db.Decimal(10, 2)
  serviceRate   Decimal            @default(10) @db.Decimal(5, 2)
  serviceCharge Decimal            @default(0) @db.Decimal(10, 2)
  discount      Decimal            @default(0) @db.Decimal(10, 2)
  total         Decimal            @default(0) @db.Decimal(10, 2)
  paymentStatus OrderPaymentStatus @default(UNPAID)
  paymentMethod String?
  paidAmount    Decimal?           @db.Decimal(10, 2)
  changeAmount  Decimal?           @db.Decimal(10, 2)
  notes         String?            @db.Text
  confirmedAt   DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id])
  table         RestaurantTable? @relation(fields: [tableId], references: [id])
  items         OrderItem[]
  kitchenOrders KitchenOrder[]

  @@index([tenantId])
  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id           String          @id @default(uuid())
  tenantId     String?
  orderId      String
  menuItemId   String
  quantity     Int
  unitPrice    Decimal         @db.Decimal(10, 2)
  totalPrice   Decimal         @db.Decimal(10, 2)
  status       OrderItemStatus @default(PENDING)
  notes        String?
  modifiers    Json?
  sentToKitchen Boolean        @default(false)
  sentAt       DateTime?
  preparedAt   DateTime?
  servedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
  @@map("order_items")
}

// ─── Kitchen ─────────────────────────────────────────────────────────────────

model KitchenOrder {
  id          String          @id @default(uuid())
  tenantId    String?
  orderId     String
  priority    KitchenPriority @default(NORMAL)
  status      OrderItemStatus @default(PENDING)
  stationName String?
  notes       String?         @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@index([priority])
  @@map("kitchen_orders")
}

model Employee {
  id             String    @id @default(uuid())
  tenantId       String?
  firstName      String
  lastName       String
  nickname       String?
  email          String
  employeeCode   String?
  department     String?
  position       String?
  departmentId   String?
  positionId     String?
  phone          String?
  dateOfBirth    DateTime?
  nationalId     String?
  gender         String?   // MALE | FEMALE | OTHER | NOT_SPECIFIED
  employmentType String?   @default("FULLTIME") // FULLTIME | TEMPORARY | DAILY | CONTRACT
  bankName       String?
  notes          String?   @db.Text
  status         String    @default("ACTIVE") // ACTIVE | ON_LEAVE | INACTIVE | SUSPENDED | TERMINATED | RESIGNED
  baseSalary     Decimal?  @db.Decimal(12, 2)
  initialSalary  Decimal?  @db.Decimal(12, 2)
  bankAccount    String?
  startDate      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // NEW: HR Financial & Detailed Info
  propertyId     String? // hotelId
  taxId          String?
  socialSecurity String?
  allowance      Decimal?  @db.Decimal(12, 2)
  overtime       Decimal?  @db.Decimal(12, 2)
  positionBonus  Decimal?  @db.Decimal(12, 2)
  educations     Json?
  workExperiences Json?
  emergencyContacts Json?

  // HR Add-on: reverse relation — one Employee can be linked to one Staff record
  staff         Staff?          @relation("StaffEmployee")
  property      Property?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  hrDepartment  HrDepartment?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  hrPosition    HrPosition?     @relation(fields: [positionId], references: [id], onDelete: SetNull)
  attendances   HrAttendance[]
  leaveRequests HrLeaveRequest[]
  payrolls      HrPayroll[]
  performances  HrPerformance[]

  // employeeCode unique per hotel (property) within a tenant
  // — same code can exist in different hotels of the same tenant
  // NOTE: MySQL allows multiple NULLs in unique index; application layer enforces
  //       propertyId-scoped check when propertyId is known at create time.
  @@unique([tenantId, propertyId, employeeCode])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([propertyId])
  @@index([departmentId])
  @@index([positionId])
  @@index([employeeCode])
  @@map("employees")
}

model HrDepartment {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  nameEn      String?
  code        String
  description String?  @db.Text
  color       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions HrPosition[]
  employees Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("hr_departments")
}

model HrPosition {
  id           String   @id @default(uuid())
  tenantId     String
  departmentId String
  name         String
  nameEn       String?
  code         String?
  level        Int      @default(1)
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department HrDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employees  Employee[]

  @@index([tenantId])
  @@index([departmentId])
  @@map("hr_positions")
}

model HrLeaveType {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  nameEn         String?
  code           String
  maxDaysPerYear Int?
  isPaid         Boolean  @default(true)
  requiresDoc    Boolean  @default(false)
  isActive       Boolean  @default(true)
  color          String?
  description    String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("hr_leave_types")

  leaveRequests HrLeaveRequest[]
}

model HrShiftType {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  nameEn       String?
  code         String
  startTime    String
  endTime      String
  breakMinutes Int      @default(60)
  isActive     Boolean  @default(true)
  color        String?
  description  String?  @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("hr_shift_types")
}

model HrAllowanceType {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  nameEn      String?
  code        String
  isTaxable   Boolean  @default(false)
  isActive    Boolean  @default(true)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("hr_allowance_types")
}

model HrDeductionType {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  nameEn      String?
  code        String
  isRequired  Boolean  @default(false)
  isActive    Boolean  @default(true)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("hr_deduction_types")
