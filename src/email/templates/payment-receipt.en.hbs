<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment Receipt</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f4f4;">
  <table width="100%" style="background-color: #f4f4f4; padding: 20px 0;">
    <tr>
      <td align="center">
        <table width="600" style="background-color: #ffffff; border-radius: 8px;">
          <tr>
            <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 30px; text-align: center;">
              <h1 style="color: #ffffff; margin: 0;">{{hotelName}}</h1>
              <p style="color: rgba(255,255,255,0.9); margin: 10px 0 0 0;">Payment Receipt</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px; text-align: center;">
              <h2 style="color: #4caf50;">Payment Successful</h2>
              <table width="100%" style="background-color: #f8f9fa; border-radius: 8px; margin: 20px 0;">
                <tr>
                  <td style="padding: 25px;">
                    <table width="100%" cellpadding="5">
                      <tr><td style="color: #888;">Receipt No:</td><td style="color: #333; font-weight: bold;">{{receiptNumber}}</td></tr>
                      <tr><td style="color: #888;">Booking No:</td><td style="color: #333;">#{{bookingNumber}}</td></tr>
                      <tr><td style="color: #888;">Date:</td><td style="color: #333;">{{paymentDate}}</td></tr>
                      <tr><td style="color: #888;">Method:</td><td style="color: #333;">{{paymentMethod}}</td></tr>
                      <tr><td style="color: #333; font-weight: bold;">Amount:</td><td style="color: #667eea; font-weight: bold; font-size: 20px;">{{formatNumber amount}}</td></tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="background-color: #f8f9fa; padding: 20px; text-align: center;">
              <p style="color: #888; font-size: 12px;">© {{currentYear}} {{hotelName}}</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
